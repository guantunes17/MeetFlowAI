{
  "name": "meetflow-ai-mvp-frontend",
  "private": true,
  "version": "0.2.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:tauri": "cross-env TAURI_BUILD=1 NEXT_PUBLIC_API_URL=http://127.0.0.1:8000 next build",
    "start": "next start",
    "tauri": "tauri",
    "tauri:preflight": "node scripts/tauri-preflight.mjs",
    "tauri:sidecar": "python ../backend/scripts/build_sidecar.py",
    "tauri:dev": "npm run tauri:preflight && npm run tauri:sidecar && tauri dev",
    "tauri:build": "npm run tauri:preflight && npm run tauri:sidecar && tauri build"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
